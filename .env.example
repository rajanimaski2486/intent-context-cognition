# OpenSearch (Aiven for OpenSearch)
OPENSEARCH_URL=https://os-9278351-reveal-demo.h.aivencloud.com:13385
OPENSEARCH_USERNAME=avnadmin
OPENSEARCH_PASSWORD=your_actual_password

# Pexels API (data pipeline only)
PEXELS_API_KEY=your_pexels_key

# OpenAI — embeddings (data pipeline only)
OPENAI_EMBEDDING_API_KEY=your_openai_key

# Primary LLM — NVIDIA NIM (agent trace)
NVIDIA_API_KEY=your_nvidia_key
LLM_PRIMARY_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_PRIMARY_MODEL=meta/llama-3.1-8b-instruct
LLM_TIMEOUT_MS=120000
LLM_MAX_RETRIES=2

# Fallback LLM — OpenAI (agent trace)
OPENAI_API_KEY=your_openai_key
LLM_FALLBACK_BASE_URL=https://api.openai.com/v1
LLM_FALLBACK_MODEL=gpt-4o-mini

# Vision rerank models (Cognition stage). The header "Current / NVIDIA" toggle
# picks which one runs per request; both cache verdicts on the OpenSearch domain.
#   current → RERANK_MODEL (OpenAI, one holistic multi-image call)
#   nvidia  → RERANK_NVIDIA_MODEL (NIM takes 1 image/request, so each candidate
#             is scored individually and sorted)
RERANK_MODEL=gpt-4o
RERANK_NVIDIA_MODEL=meta/llama-3.2-11b-vision-instruct

# Provider toggle (header): "current" = scripted agent trace + OpenAI rerank;
# "nvidia" = live llama-3.1-8b trace (strict, no fallback) + NVIDIA vision rerank.
# Both NVIDIA stages cache to the icc_trace_cache / icc_rerank_cache indices.

NEXT_PUBLIC_APP_NAME=Reveal
