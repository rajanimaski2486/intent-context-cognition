# OpenSearch (Aiven for OpenSearch) — primary cluster
OPENSEARCH_URL=https://os-9278351-reveal-demo.h.aivencloud.com:13385
OPENSEARCH_USERNAME=avnadmin
OPENSEARCH_PASSWORD=your_actual_password

# OpenSearch fallback / standby cluster (second Aiven service). OPTIONAL — when
# all three are set, the search read path automatically fails over to this
# cluster if the primary is unreachable or overloaded (connection error, 5xx,
# or 429). Leave unset to disable failover. Backfill it offline first (the data
# pipeline scripts accept `--target fallback` to point at this cluster).
OPENSEARCH_FALLBACK_URL=
OPENSEARCH_FALLBACK_USERNAME=
OPENSEARCH_FALLBACK_PASSWORD=

# Primary request timeout in ms (default 5000). Kept short so a slow/overloaded
# primary trips failover to the standby in seconds instead of waiting out the
# opensearch-js 30s default. Lower it for an even snappier failover under load.
OPENSEARCH_PRIMARY_TIMEOUT_MS=5000

# Pexels API (data pipeline only)
PEXELS_API_KEY=your_pexels_key

# OpenAI — embeddings (data pipeline only)
OPENAI_EMBEDDING_API_KEY=your_openai_key

# Primary LLM — NVIDIA NIM (default for agent trace + vision rerank).
# Set this and NVIDIA is used for everything. If it is missing (or a call
# fails), the app automatically falls back to OpenAI below.
NVIDIA_API_KEY=your_nvidia_key
LLM_PRIMARY_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_PRIMARY_MODEL=meta/llama-3.1-8b-instruct
LLM_TIMEOUT_MS=120000
LLM_MAX_RETRIES=2

# Fallback LLM — OpenAI. Used only when NVIDIA_API_KEY is unset or a NVIDIA
# call fails (and when the header toggle is set to "OpenAI" explicitly).
OPENAI_API_KEY=your_openai_key
LLM_FALLBACK_BASE_URL=https://api.openai.com/v1
LLM_FALLBACK_MODEL=gpt-4o-mini

# Vision rerank models (Cognition stage). The header "Current / NVIDIA" toggle
# picks which one runs per request; both cache verdicts on the OpenSearch domain.
#   current → RERANK_MODEL (OpenAI, one holistic multi-image call)
#   nvidia  → RERANK_NVIDIA_MODEL (NIM takes 1 image/request, so each candidate
#             is scored individually and sorted)
RERANK_MODEL=gpt-4o
RERANK_NVIDIA_MODEL=meta/llama-3.2-11b-vision-instruct

# Provider toggle (header): defaults to "nvidia" = live llama-3.1-8b trace +
# NVIDIA vision rerank, with automatic OpenAI fallback when NVIDIA is unavailable.
# "current" = scripted agent trace + OpenAI rerank. Both stages cache to the
# icc_trace_cache / icc_rerank_cache indices, keyed by the resolved model name.

NEXT_PUBLIC_APP_NAME=Reveal
